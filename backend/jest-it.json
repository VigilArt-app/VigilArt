{
  "testPathIgnorePatterns": ["<rootDir>/dist/"],
  "preset": "ts-jest",
  "testEnvironment": "node",
  "testRegex": ".it-spec.ts$",
  "transformIgnorePatterns": ["/node_modules/(?!@google-cloud|uuid)/"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "modulePathIgnorePatterns": ["<rootDir>/dist/"]
}
