{
  "name": "@vigilart/backend",
  "version": "0.1.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.968.0",
    "@aws-sdk/s3-request-presigner": "^3.968.0",
    "@google-cloud/vision": "^5.3.4",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.2.3",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@vigilart/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "cookie-parser": "^1.4.7",
    "mime-types": "^3.0.2",
    "nestjs-zod": "^5.1.1",
    "pdfkit": "^0.17.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "rxjs": "^7.8.2",
    "zod": "^4.1.13"
  },
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "test:it": "jest --config ./jest.config.ts",
    "test:e2e": "cross-env NODE_ENV=test NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest --config ./test/jest-e2e.config.ts --runInBand",
    "db:reset": "dotenv -e ../.env -- sh -c 'pnpm prisma migrate reset && pnpm db:seed:dev'",
    "db:push": "dotenv -e ../.env -- pnpm prisma db push",
    "db:migrate:prod": "pnpm prisma migrate deploy",
    "db:generate": "pnpm prisma generate",
    "db:migrate:dev": "dotenv -e ../.env -- pnpm prisma migrate dev",
    "db:studio": "dotenv -e ../.env -- pnpm prisma studio --config ./prisma.config.ts --port 5555 --browser none",
    "db:seed:dev": "pnpm prisma db seed --config ./prisma.config.ts",
    "db:seed:prod": "node dist/prisma/seeds/index.js"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.12",
    "@nestjs/testing": "^11.1.8",
    "@testcontainers/postgresql": "^11.8.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/mocha": "^10.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.25",
    "@types/pdfkit": "^0.17.4",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.2.0",
    "prisma": "^7.2.0",
    "supertest": "^7.1.4",
    "prisma-zod-generator": "^2.1.2",
    "testcontainers": "^11.8.1",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3"
  }
}
