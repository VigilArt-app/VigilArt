{
  "name": "vigilart",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "pnpm -r run build",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter web-app dev",
    "dev": "pnpm --parallel --filter \"backend...\" --filter \"web-app...\" dev",
    "test:e2e": "pnpm --filter backend test:e2e",
    "start:backend": "pnpm --filter backend start",
    "start:frontend": "pnpm --filter web-app start"
  }
}