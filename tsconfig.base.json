{
  "references": [
    { "path": "./shared" },
    { "path": "./backend" },
    { "path": "./frontend" }
  ],
  "compilerOptions": {
    "paths": {
      "@vigilart/shared/*": ["./shared/src/*"]
    },
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "module": "node16",
    "moduleResolution": "node16",
    "composite": true,
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true
  },
  "exclude": ["node_modules", "dist"]
}